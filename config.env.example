# Variables collectées par le script (sauvegardées automatiquement dans /var/lib/install-ubuntu/config.env).
# Tu peux pré-remplir ce fichier (le copier en /var/lib/install-ubuntu/config.env avant lancement)
# pour skipper les prompts.

HOSTNAME=vps-monsite
FQDN=vps-monsite.example.com
DOMAIN=nomdusite.com
SLUG=nomdusite-com

REPO_URL=git@github.com:user/repo.git
PROD_BRANCH=main
STAGING_BRANCH=staging

# Sous-dossier de l'app Laravel dans le repo (monorepo).
# Vide = app à la racine. Ex: web-overlay si /web-overlay/{public,artisan,composer.json,…}.
APP_SUBDIR=

ALERT_EMAIL=ubuntu@vps-monsite.example.com

# IPs admin a NE JAMAIS bannir dans CrowdSec (espace-separe, IPs ou CIDR).
# Si vide, le prompt suggere automatiquement l'IP de la session SSH courante.
# Defense in depth : RFC1918 + localhost sont toujours whitelist.
ADMIN_WHITELIST_IPS=

# Détectées automatiquement par 01-preflight :
# UBUNTU_RELEASE=24.04
# UBUNTU_CODENAME=noble
# PHP_VERSION=8.5
